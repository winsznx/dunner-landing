# Resend — email sending for the early access waitlist
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Optional — verified sender. Until you verify a domain in Resend,
# use the default 'onboarding@resend.dev' which only delivers to
# the email you signed up with.
RESEND_FROM_EMAIL=Dunner <onboarding@resend.dev>

# Optional — Resend audience ID to store waitlist contacts
# Create one at https://resend.com/audiences
RESEND_AUDIENCE_ID=
